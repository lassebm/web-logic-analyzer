{
  "name": "web-logic-analyzer",
  "version": "0.1.0",
  "description": "Browser-based logic analyzer for FX2LP (fx2lafw) devices over WebUSB",
  "author": "Lasse Bang Mikkelsen",
  "license": "MIT",
  "homepage": "https://lassebm.github.io/web-logic-analyzer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/lassebm/web-logic-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/lassebm/web-logic-analyzer/issues"
  },
  "keywords": [
    "logic-analyzer",
    "webusb",
    "fx2lafw",
    "fx2lp",
    "sigrok",
    "protocol-decoder",
    "uart",
    "spi",
    "i2c",
    "1-wire",
    "can"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.1.1",
    "@types/w3c-web-usb": "^1.0.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
